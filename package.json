{
  "name": "pi-powershell",
  "version": "2.0.3",
  "description": "Robust PowerShell extension for pi on Windows — token-based bash-to-PS translation, background jobs, diagnostics",
  "keywords": [
    "pi-package",
    "pi-extension",
    "powershell",
    "windows",
    "bash-to-powershell"
  ],
  "type": "module",
  "files": [
    "src",
    "aliases.json",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run"
  },
  "pi": {
    "ps": {
      "executable": "auto",
      "translate": "hint",
      "strict": false,
      "utf8": true,
      "killTreeOnAbort": true,
      "aliasFile": "~/.pi-ps/aliases.json"
    },
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "author": "alessandro@pungitore.ch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pungggi/pi-ps.git"
  },
  "bugs": {
    "url": "https://github.com/pungggi/pi-ps/issues"
  },
  "homepage": "https://github.com/pungggi/pi-ps#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "typescript": "^5.9.0",
    "vitest": "^3.1.0"
  }
}
